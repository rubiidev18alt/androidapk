<resources>
    <!--
        Expressive shape tension: three huge corners plus one tighter corner.
        Parent uses the stable MaterialComponents shape family instead of a Material3
        resource name that is not present in older MDC XML resources.
    -->
    <style name="ShapeAppearance.QuirkMusic.HeroCard" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">36dp</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomLeft">12dp</item>
        <item name="cornerSizeBottomRight">36dp</item>
    </style>
</resources>
