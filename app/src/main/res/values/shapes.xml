<resources>
    <!--
        Expressive shape tension: three huge corners plus one tighter corner.
        This avoids the flat, uniform card silhouette common in older Material layouts.
    -->
    <style name="ShapeAppearance.SimpleApk.HeroCard" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">36dp</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomLeft">12dp</item>
        <item name="cornerSizeBottomRight">36dp</item>
    </style>
</resources>
