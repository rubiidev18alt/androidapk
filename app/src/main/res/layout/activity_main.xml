<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md3_expressive_surface"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!--
        Expressive containment: a high-contrast primary container anchors the screen,
        while intentionally uneven corners create more visual tension than a basic card.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/heroCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/md3_expressive_primary_container"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.QuirkMusic.HeroCard"
        app:strokeColor="@color/md3_expressive_on_primary_container"
        app:strokeWidth="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="32dp"
            android:paddingEnd="28dp"
            android:paddingBottom="28dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/eyebrowText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/expressive_badge_background"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="QUIRKMUSIC"
                android:textAllCaps="true"
                android:textColor="@color/md3_expressive_on_tertiary_container"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/heroTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="QuirkMusic, now with actual energy."
                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline4"
                android:textColor="@color/md3_expressive_on_primary_container"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/bodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Semantic colors, stronger contrast, editorial scale, and asymmetric containment give this app a music-ready identity."
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="@color/md3_expressive_on_primary_container" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/primaryAction"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:minHeight="56dp"
                android:paddingStart="26dp"
                android:paddingEnd="26dp"
                android:text="Explore now"
                android:textAllCaps="true"
                android:textColor="@color/md3_expressive_on_secondary_container"
                android:textStyle="bold"
                app:backgroundTint="@color/md3_expressive_secondary_container"
                app:cornerRadius="28dp"
                app:icon="@android:drawable/ic_menu_compass"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@color/md3_expressive_on_secondary_container"
                app:rippleColor="@color/md3_expressive_tertiary_container" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
